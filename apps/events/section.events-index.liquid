{% comment %}
  Common Lands Events — Index (Calendar View, OS 2.0)
  Paste into your theme at: sections/events-index.liquid

  Referenced from: templates/page.events.json (on the "Events" Shopify Page)

  Renders two months (current + next) as calendar grids. Each day cell shows
  chips for events on that day; each chip links to its parent EventSeries
  detail page at /pages/events/<series-handle>.

  Metaobject API ids in use (cannot be renamed after creation):
    Series:     `event`
    Occurrence: `event_occurence` (single 'r' — preserved from initial setup)

  All times in the store TZ (Shopify renders | date in shop time automatically).
{% endcomment %}

{%- assign now_unix = 'now' | date: '%s' | times: 1 -%}
{%- assign day_sec = 86400 -%}
{%- assign today_ymd = 'now' | date: '%Y-%m-%d' -%}

{%- comment -%} Determine the first day of the current month and next month (UTC-safe via day-strings). {%- endcomment -%}
{%- assign cur_y = 'now' | date: '%Y' | times: 1 -%}
{%- assign cur_m = 'now' | date: '%m' | times: 1 -%}
{%- assign next_m = cur_m | plus: 1 -%}
{%- assign next_y = cur_y -%}
{%- if next_m > 12 -%}{%- assign next_m = 1 -%}{%- assign next_y = cur_y | plus: 1 -%}{%- endif -%}

{%- comment -%}
  Build per-day event list. Format per record (pipe-separated):
    date | seriesUrl | seriesTitle | timeStr | cancelled | color
  Records joined by `;;`.
{%- endcomment -%}
{%- assign event_index = '' -%}
{%- assign horizon_unix = now_unix | plus: 7776000 -%}{%- comment -%} 90 days {%- endcomment -%}

{%- for occ in shop.metaobjects.event_occurence.values -%}
  {%- assign series = occ.series.value -%}
  {%- if series == blank -%}{%- continue -%}{%- endif -%}
  {%- if series.status.value == 'draft' -%}{%- continue -%}{%- endif -%}
  {%- assign s_unix = occ.start_datetime.value | date: '%s' | times: 1 -%}
  {%- if s_unix == 0 -%}{%- continue -%}{%- endif -%}
  {%- if s_unix > horizon_unix -%}{%- continue -%}{%- endif -%}
  {%- assign ymd = s_unix | date: '%Y-%m-%d' -%}
  {%- assign t = s_unix | date: '%-I:%M%P' | replace: ':00', '' -%}
  {%- assign title_safe = series.title.value | replace: '|', '/' | replace: ';;', '/' -%}
  {%- assign is_cancel = '0' -%}
  {%- if occ.cancelled.value -%}{%- assign is_cancel = '1' -%}{%- endif -%}

  {%- comment -%} Prefer Shopify's auto-generated URL; fall back to /pages/events/<handle>. {%- endcomment -%}
  {%- assign series_url = series.system.url -%}
  {%- if series_url == blank or series_url == '' -%}
    {%- assign series_url = '/pages/events/' | append: series.handle -%}
  {%- endif -%}

  {%- comment -%} Optional per-series color field; default to amber if unset. {%- endcomment -%}
  {%- assign series_color = series.color.value | default: '#f59e0b' -%}

  {%- assign event_index = event_index | append: ymd | append: '|' | append: series_url | append: '|' | append: title_safe | append: '|' | append: t | append: '|' | append: is_cancel | append: '|' | append: series_color | append: ';;' -%}
{%- endfor -%}

{%- assign all_events = event_index | split: ';;' -%}

<div class="cl-events-page">
  <style>
    .cl-events-page {
      max-width: 1080px !important;
      margin: 48px auto !important;
      padding: 0 24px !important;
      color: #e4e4e7 !important;
    }
    .cl-events-page * { box-sizing: border-box; }
    .cl-events-header { text-align: center !important; margin-bottom: 36px !important; }
    .cl-events-header h1 {
      font-size: 44px !important;
      font-weight: 800 !important;
      margin: 0 0 12px !important;
      letter-spacing: -0.02em !important;
      color: #e4e4e7 !important;
    }
    .cl-events-header p {
      color: #a1a1aa !important;
      font-size: 18px !important;
      max-width: 640px !important;
      margin: 0 auto !important;
      line-height: 1.6 !important;
    }
    .cl-month {
      background: #1a1b23 !important;
      border: 1px solid #2a2b35 !important;
      border-radius: 16px !important;
      padding: 24px !important;
      margin-bottom: 24px !important;
    }
    .cl-month-title {
      font-size: 22px !important;
      font-weight: 700 !important;
      color: #e4e4e7 !important;
      margin: 0 0 16px !important;
      letter-spacing: -0.01em !important;
    }
    .cl-cal-grid {
      display: grid !important;
      grid-template-columns: repeat(7, minmax(0, 1fr)) !important;
      gap: 4px !important;
    }
    .cl-cal-dow {
      font-size: 11px !important;
      font-weight: 700 !important;
      letter-spacing: 0.08em !important;
      text-transform: uppercase !important;
      color: #71717a !important;
      text-align: center !important;
      padding: 6px 0 !important;
    }
    .cl-cal-cell {
      background: #15161d !important;
      border: 1px solid #22232d !important;
      border-radius: 8px !important;
      min-height: 88px !important;
      padding: 6px !important;
      display: flex !important;
      flex-direction: column !important;
      gap: 3px !important;
      position: relative !important;
      min-width: 0 !important;
      overflow: hidden !important;
    }
    .cl-cal-cell.is-other-month { opacity: 0.25 !important; }
    .cl-cal-cell.is-past { opacity: 0.45 !important; }
    .cl-cal-cell.is-today {
      border-color: #f59e0b !important;
      background: rgba(245, 158, 11, 0.06) !important;
    }
    .cl-cal-daynum {
      font-size: 12px !important;
      font-weight: 600 !important;
      color: #71717a !important;
      margin-bottom: 2px !important;
    }
    .cl-cal-cell.is-today .cl-cal-daynum { color: #f59e0b !important; }
    .cl-chip {
      display: block !important;
      padding: 3px 6px !important;
      border-radius: 5px !important;
      font-size: 11px !important;
      font-weight: 600 !important;
      text-decoration: none !important;
      line-height: 1.3 !important;
      overflow: hidden !important;
      text-overflow: ellipsis !important;
      white-space: nowrap !important;
      min-width: 0 !important;
      max-width: 100% !important;
      width: 100% !important;
      box-sizing: border-box !important;
      transition: filter 0.12s !important;
      border: 1px solid transparent !important;
    }
    .cl-chip:hover { filter: brightness(1.25) !important; }
    .cl-chip.cancelled {
      opacity: 0.5 !important;
      text-decoration: line-through !important;
    }
    .cl-chip-time { font-weight: 700 !important; opacity: 0.85 !important; }
    .cl-events-empty {
      text-align: center !important;
      color: #71717a !important;
      padding: 60px 20px !important;
      font-size: 16px !important;
    }
    @media (max-width: 720px) {
      .cl-events-page { margin: 24px auto !important; padding: 0 12px !important; }
      .cl-events-header h1 { font-size: 30px !important; }
      .cl-month { padding: 14px !important; }
      .cl-month-title { font-size: 18px !important; }
      .cl-cal-grid { gap: 2px !important; }
      .cl-cal-dow { font-size: 9px !important; padding: 4px 0 !important; }
      .cl-cal-cell {
        min-height: 64px !important;
        padding: 3px !important;
        border-radius: 5px !important;
      }
      .cl-cal-daynum { font-size: 10px !important; }
      .cl-chip {
        font-size: 9px !important;
        padding: 2px 3px !important;
        border-radius: 3px !important;
      }
      .cl-chip-time { display: none !important; }
    }
  </style>

  <div class="cl-events-header">
    <h1>{{ section.settings.heading | default: 'Events at Common Lands' }}</h1>
    <p>{{ section.settings.subheading | default: 'Tournaments, leagues, and casual play in Flower Mound, TX. Walk-ins welcome — no registration needed.' }}</p>
  </div>

  {%- comment -%} Render two months: current and next. {%- endcomment -%}
  {%- for month_offset in (0..1) -%}
    {%- if month_offset == 0 -%}
      {%- assign render_y = cur_y -%}
      {%- assign render_m = cur_m -%}
    {%- else -%}
      {%- assign render_y = next_y -%}
      {%- assign render_m = next_m -%}
    {%- endif -%}

    {%- comment -%} Build first-day timestamp via formatted string "YYYY-MM-01". {%- endcomment -%}
    {%- assign mm_pad = render_m | prepend: '00' | slice: -2, 2 -%}
    {%- assign first_str = render_y | append: '-' | append: mm_pad | append: '-01T12:00:00' -%}
    {%- assign first_unix = first_str | date: '%s' | times: 1 -%}
    {%- assign month_title = first_unix | date: '%B %Y' -%}
    {%- assign first_dow = first_unix | date: '%w' | times: 1 -%}{%- comment -%} 0=Sun..6=Sat {%- endcomment -%}

    {%- comment -%} Compute last day of month: walk forward, stop when month changes. {%- endcomment -%}
    {%- assign last_day = 28 -%}
    {%- for probe_d in (29..31) -%}
      {%- assign probe_unix = first_unix | plus: probe_d | minus: 1 | times: 1 -%}
      {%- comment -%} probe day = first_unix + (d-1)*86400 {%- endcomment -%}
      {%- assign probe_unix = first_unix | plus: 0 -%}
      {%- assign offset_sec = probe_d | minus: 1 | times: day_sec -%}
      {%- assign probe_unix = first_unix | plus: offset_sec -%}
      {%- assign probe_m = probe_unix | date: '%m' | times: 1 -%}
      {%- if probe_m == render_m -%}
        {%- assign last_day = probe_d -%}
      {%- endif -%}
    {%- endfor -%}

    <div class="cl-month">
      <div class="cl-month-title">{{ month_title }}</div>
      <div class="cl-cal-grid">
        <div class="cl-cal-dow">Sun</div>
        <div class="cl-cal-dow">Mon</div>
        <div class="cl-cal-dow">Tue</div>
        <div class="cl-cal-dow">Wed</div>
        <div class="cl-cal-dow">Thu</div>
        <div class="cl-cal-dow">Fri</div>
        <div class="cl-cal-dow">Sat</div>

        {%- comment -%} Leading empty cells (days from previous month). {%- endcomment -%}
        {%- for i in (1..first_dow) -%}
          <div class="cl-cal-cell is-other-month"></div>
        {%- endfor -%}

        {%- comment -%} Days of this month. {%- endcomment -%}
        {%- for day in (1..last_day) -%}
          {%- assign day_pad = day | prepend: '00' | slice: -2, 2 -%}
          {%- assign cell_ymd = render_y | append: '-' | append: mm_pad | append: '-' | append: day_pad -%}
          {%- assign is_today = false -%}
          {%- if cell_ymd == today_ymd -%}{%- assign is_today = true -%}{%- endif -%}
          {%- assign is_past = false -%}
          {%- if cell_ymd < today_ymd -%}{%- assign is_past = true -%}{%- endif -%}

          <div class="cl-cal-cell{% if is_today %} is-today{% endif %}{% if is_past %} is-past{% endif %}">
            <div class="cl-cal-daynum">{{ day }}</div>
            {%- for ev_str in all_events -%}
              {%- if ev_str == '' -%}{%- continue -%}{%- endif -%}
              {%- assign ev_parts = ev_str | split: '|' -%}
              {%- if ev_parts[0] != cell_ymd -%}{%- continue -%}{%- endif -%}
              {%- assign ev_url = ev_parts[1] -%}
              {%- assign ev_title = ev_parts[2] -%}
              {%- assign ev_time = ev_parts[3] -%}
              {%- assign ev_cancel = ev_parts[4] -%}
              {%- assign ev_color = ev_parts[5] | default: '#f59e0b' -%}
              <a href="{{ ev_url }}"
                 class="cl-chip{% if ev_cancel == '1' %} cancelled{% endif %}"
                 style="background: {{ ev_color }}26; border-color: {{ ev_color }}59; color: {{ ev_color }};"
                 title="{{ ev_title | escape }} · {{ ev_time }}">
                <span class="cl-chip-time">{{ ev_time }}</span> {{ ev_title | escape }}
              </a>
            {%- endfor -%}
          </div>
        {%- endfor -%}

        {%- comment -%} Trailing empty cells to fill the final week. {%- endcomment -%}
        {%- assign used_cells = first_dow | plus: last_day -%}
        {%- assign mod7 = used_cells | modulo: 7 -%}
        {%- if mod7 > 0 -%}
          {%- assign trailing = 7 | minus: mod7 -%}
          {%- for i in (1..trailing) -%}
            <div class="cl-cal-cell is-other-month"></div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Events Index",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Events at Common Lands"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Tournaments, leagues, and casual play in Flower Mound, TX. Walk-ins welcome — no registration needed."
    }
  ],
  "presets": [
    {
      "name": "Events Index"
    }
  ]
}
{% endschema %}
