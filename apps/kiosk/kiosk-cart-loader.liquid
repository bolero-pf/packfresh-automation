{% comment %}
    Kiosk cart loader — accepts variant IDs via URL param, adds to cart via AJAX, redirects to /cart
    Used by kiosk.pack-fresh.com for Champion checkout cart merge.

    Strategy: bulk /cart/add.js with the whole batch, then on failure recurse
    by splitting in half. Shopify's bulk add is atomic — one bad variant kills
    the batch — so bisecting localizes the failure in O(log N) calls instead
    of N sequential adds (44 sequential adds was taking 10+ minutes).
  {% endcomment %}

  <div id="kiosk-loading"
  style="display:flex;align-items:center;justify-content:center;min-height:60vh;font-family:sans-serif;">
    <div style="text-align:center;">
      <p style="font-size:1.2rem;font-weight:600;">Adding cards to your cart...</p>
      <p style="color:#666;font-size:0.9rem;" id="kiosk-status">Please wait</p>
    </div>
  </div>

  <script>
  (async function() {
    const params = new URLSearchParams(window.location.search);
    const raw = params.get('items') || '';
    const ids = raw.split(',').map(s => s.trim()).filter(Boolean);
    const statusEl = document.getElementById('kiosk-status');

    if (!ids.length) {
      statusEl.textContent = 'No items to add. Redirecting...';
      setTimeout(() => window.location.href = '/cart', 1500);
      return;
    }

    const added = new Set();
    const failed = new Set();
    let calls = 0;

    function updateStatus() {
      const done = added.size + failed.size;
      statusEl.textContent =
        `Adding cards... ${done} of ${ids.length} (${calls} request${calls === 1 ? '' : 's'})`;
    }

    // Bulk-add a slice. On atomic failure, bisect.
    async function bulkAdd(slice) {
      if (slice.length === 0) return;
      calls++;
      updateStatus();
      try {
        const items = slice.map(id => ({ id: parseInt(id, 10), quantity: 1 }));
        const resp = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items })
        });
        if (resp.ok) {
          slice.forEach(id => added.add(id));
          updateStatus();
          return;
        }
      } catch (e) {
        // Network error — treat as failure for this slice and bisect.
        console.warn('Kiosk cart-add network error on slice', slice, e);
      }
      if (slice.length === 1) {
        failed.add(slice[0]);
        updateStatus();
        return;
      }
      const mid = Math.floor(slice.length / 2);
      await bulkAdd(slice.slice(0, mid));
      await bulkAdd(slice.slice(mid));
    }

    await bulkAdd(ids);

    if (failed.size === 0) {
      statusEl.textContent = 'Done! Redirecting to your cart...';
      window.location.href = '/cart';
    } else if (added.size > 0) {
      statusEl.textContent =
        `Added ${added.size} of ${ids.length} cards. Redirecting to your cart...`;
      console.warn('Kiosk cart-add: failed variant IDs', Array.from(failed));
      setTimeout(() => window.location.href = '/cart', 2000);
    } else {
      statusEl.textContent = 'Could not add any cards. Please try again in a moment.';
      console.error('Kiosk cart-add: ALL variants failed', Array.from(failed));
    }
  })();
  </script>
