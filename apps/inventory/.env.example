# Copy to .env for local dev. In Railway, set these as environment variables.

# Postgres (shared with intake/ingestion)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Shopify
SHOPIFY_TOKEN=shpat_xxxxxxxxxxxx
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_STORE_HANDLE=your-store          # short handle for admin links
LOCATION_ID=12345678901                  # Shopify location ID

# Auth (Basic HTTP auth for the dashboard)
INVENTORY_USER=admin
INVENTORY_PASS=changeme

# PPT (PokemonPriceTracker)
PPT_API_KEY=your-ppt-api-key

# Optional: remove.bg API key for image background removal
# If not set, falls back to local rembg (slower, no API cost)
REMOVE_BG_API_KEY=

# Safety: set to "1" to prevent any writes to Shopify
PF_DRY_RUN=0

# Flask
SECRET_KEY=change-me-in-production
